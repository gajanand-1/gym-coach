# ============================================================
#  Personal AI Gym Coach — Environment Configuration Template
#  Copy this file to .env and fill in your values:
#      cp .env.example .env
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# ── DATABASE (optional — defaults to SQLite) ─────────────────
# Leave blank to use the default SQLite file at database/gym_coach.db
# For PostgreSQL: postgresql://user:password@localhost:5432/gym_coach
DATABASE_URL=

# ── APP SETTINGS ─────────────────────────────────────────────
# Streamlit server port (default: 8501)
PORT=8501

# Debug mode — set to true for verbose SQL logging
DEBUG=false

# ── OPTIONAL FEATURES ────────────────────────────────────────
# Required only if using image OCR for mess menu upload
# Install tesseract: https://github.com/tesseract-ocr/tesseract
TESSERACT_CMD=/usr/bin/tesseract
